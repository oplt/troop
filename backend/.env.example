APP_NAME=fullstack-app
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORE_DOMAIN_SINGULAR=Project
CORE_DOMAIN_PLURAL=Projects
PLATFORM_DEFAULT_MODULE_PACK=full_platform

DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app_db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=true
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_EMAIL_QUEUE=email
CELERY_RESULT_EXPIRES_SECONDS=3600

JWT_SECRET=replace-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=http://localhost:5173
ADMIN_SIGNUP_INVITE_CODE=
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
PUBLIC_RATE_LIMIT_REQUESTS=120
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_FAILURE_LIMIT=8
AUTH_FAILURE_WINDOW_SECONDS=900
HEALTH_READY_PUBLIC=false
HEALTH_VERSION_PUBLIC=false
REQUIRE_EMAIL_VERIFICATION=true

VERIFICATION_TOKEN_TTL=86400
PASSWORD_RESET_TOKEN_TTL=3600

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=false

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
OTLP_ENDPOINT=
OTLP_INSECURE=true

STORAGE_BUCKET=app-assets
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=change-this-storage-access-key
STORAGE_SECRET_KEY=change-this-storage-secret-key
STORAGE_USE_SSL=false
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/app-assets
STORAGE_AUTO_CREATE_BUCKET=true
STORAGE_PUBLIC_READ=true
STORAGE_AVATAR_MAX_BYTES=5242880
