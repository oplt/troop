APP_NAME=fullstack-app
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORE_DOMAIN_SINGULAR=Project
CORE_DOMAIN_PLURAL=Projects
PLATFORM_DEFAULT_MODULE_PACK=full_platform

DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app_db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=true
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_EMAIL_QUEUE=email
# Optional Redis queue names for split workers (GitHub / model gateway / observability). See docs/deployment/celery-service-queues.md
CELERY_QUEUE_GITHUB=github
CELERY_QUEUE_MODEL_GATEWAY=model_gateway
CELERY_QUEUE_OBSERVABILITY=observability
CELERY_RESULT_EXPIRES_SECONDS=3600
# Celery beat (run a dedicated `celery -A backend.workers.celery_app:celery_app beat` process):
# - provider health checks, GitHub issue poll fallback, daily memory expiration sweep
PROVIDER_HEALTHCHECK_INTERVAL_MINUTES=5
GITHUB_ISSUE_POLL_INTERVAL_MINUTES=15
ORCHESTRATION_RUN_RATE_LIMIT_PER_MINUTE=30
ORCHESTRATION_SLA_SCAN_INTERVAL_MINUTES=20
# When true, orchestration uses the local heuristic model only (no outbound LLM HTTP).
ORCHESTRATION_OFFLINE_MODE=false
# When false, intra-provider model fallback (primary + fallback_model chain) is disabled.
ORCHESTRATION_PROVIDER_FAILOVER=true
# When true, worker execute_run routes run modes through LangGraph (see docs/adr/0004-*.md).
ORCHESTRATION_USE_LANGGRAPH=false
# Durable queue label for ops/UI (only "celery" is implemented; temporal is future).
ORCHESTRATION_DURABLE_QUEUE_BACKEND=celery
AGENT_TOKEN_BUDGET_WINDOW_DAYS=30

JWT_SECRET=replace-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=http://localhost:5173
ADMIN_SIGNUP_INVITE_CODE=
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
PUBLIC_RATE_LIMIT_REQUESTS=120
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_FAILURE_LIMIT=8
AUTH_FAILURE_WINDOW_SECONDS=900
HEALTH_READY_PUBLIC=false
HEALTH_VERSION_PUBLIC=false
REQUIRE_EMAIL_VERIFICATION=true

VERIFICATION_TOKEN_TTL=86400
PASSWORD_RESET_TOKEN_TTL=3600

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=false

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
OTLP_ENDPOINT=
OTLP_INSECURE=true

STORAGE_BUCKET=app-assets
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=change-this-storage-access-key
STORAGE_SECRET_KEY=change-this-storage-secret-key
STORAGE_USE_SSL=false
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/app-assets
STORAGE_AUTO_CREATE_BUCKET=true
STORAGE_PUBLIC_READ=true
STORAGE_AVATAR_MAX_BYTES=5242880

# Orchestration platform notes:
# - provider and GitHub secrets are stored through the app UI, not as required env vars
# - keep CELERY_TASK_ALWAYS_EAGER=false when you want durable background execution
# - Redis and PostgreSQL remain required for orchestration runs and approvals
# - GitHub App webhooks: POST /webhooks/github (HMAC-SHA256 via X-Hub-Signature-256) — set GITHUB_APP_WEBHOOK_SECRET
# - pgvector: use Postgres image with pgvector (see infra/docker-compose.yml) for vector similarity on knowledge chunks
