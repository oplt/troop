                    <Box
                        sx={(theme) => ({
                            p: 2.5,
                            borderRadius: 4,
                            border: `1px solid ${theme.palette.divider}`,
                        })}
                    >
                        <Stack spacing={1.5}>
                            <Typography variant="subtitle2">Create plan</Typography>
                            <Box
                                sx={{
                                    display: "grid",
                                    gap: 1.5,
                                    gridTemplateColumns: { xs: "1fr", md: "repeat(2, minmax(0, 1fr))" },
                                }}
                            >
                                <TextField
                                    label="Code"
                                    value={newPlan.code}
