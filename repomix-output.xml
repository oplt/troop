                                                    },
                                                }))
                                            }
                                        />
                                    </Stack>
                                </Box>
                            ))}
                        </Box>
                    </Box>
                </Stack>
            </SectionCard>

            <SectionCard title="Subscription plans" description="Create new commercial tiers and tune existing plans.">
